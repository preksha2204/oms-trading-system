# ═══════════════════════════════════════════════════════════════
# OMS Trading System — Environment Variables
# Copy this file to .env and edit values before running.
# NEVER commit real passwords to version control.
# ═══════════════════════════════════════════════════════════════

# ─── MySQL ───────────────────────────────────────────────────
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=oms_db
MYSQL_USER=oms_user
MYSQL_PASSWORD=oms_pass
MYSQL_ROOT_PASSWORD=oms_root_pass
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/oms_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=oms_user
SPRING_DATASOURCE_PASSWORD=oms_pass

# ─── Kafka ───────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_REPLICATION_FACTOR=1
KAFKA_NUM_PARTITIONS=12

# ─── FIX Gateway ─────────────────────────────────────────────
FIX_SENDER_COMP_ID=OMS_SERVER
FIX_TARGET_COMP_ID=TRADING_CLIENT
FIX_ACCEPT_PORT=9878
FIX_HEART_BT_INT=30
FIX_STORE_PATH=./fix-store
FIX_LOG_PATH=./fix-log

# ─── Service Ports ───────────────────────────────────────────
API_GATEWAY_PORT=8080
ORDER_MANAGEMENT_PORT=8081
MATCHING_ENGINE_PORT=8082
TRADE_EXECUTION_PORT=8083
MARKET_DATA_PORT=8084
WEBSOCKET_GATEWAY_PORT=8085
OPTIONS_PRICING_PORT=8086
REFERENCE_DATA_PORT=8087
PERSISTENCE_AUDIT_PORT=8088
NOTIFICATION_PORT=8089

# ─── JVM Settings ────────────────────────────────────────────
JAVA_OPTS_MATCHING=-XX:+UseZGC -Xmx8g -Xms2g -XX:ConcGCThreads=4 -XX:+AlwaysPreTouch
JAVA_OPTS_OMS=-XX:+UseZGC -Xmx4g -Xms1g -XX:+AlwaysPreTouch
JAVA_OPTS_TRADE=-XX:+UseZGC -Xmx4g -Xms1g
JAVA_OPTS_DEFAULT=-Xmx1g -Xms256m

# ─── Market Data ─────────────────────────────────────────────
MARKET_DATA_POLL_INTERVAL_MS=1000
MARKET_DATA_CSV_PATH=market-data/quotes.csv

# ─── Options Pricing ─────────────────────────────────────────
OPTIONS_RISK_FREE_RATE=0.05

# ─── Reference Data Service ──────────────────────────────────
REF_DATA_SERVICE_URL=http://reference-data-service:8087

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL_OMS=INFO
LOG_LEVEL_SPRING=WARN
LOG_LEVEL_KAFKA=WARN

# ─── Spring Profiles ─────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker

# ─── Node / Angular ──────────────────────────────────────────
NODE_ENV=production
ANGULAR_API_BASE_URL=http://localhost:8080
ANGULAR_WS_URL=http://localhost:8085/ws
